# Wiadomość reprezentująca obliczony offset korekcji ruchu
# Wartości wyrażone w metrach, w układzie ciała robota (body frame)

# Korekcja boczna (oś X robota): + = przesuń w lewo
float32 dx

# Korekcja przód/tył (oś Y robota): + = przesuń do przodu
float32 dy

# Korekcja góra/dół (oś Z robota): + = unieś ramię wyżej
float32 dz
